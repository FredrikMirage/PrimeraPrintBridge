<Window
    x:Class="DemoApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Single Printer Demo"
    Width="800"
    SizeToContent="Height"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <DockPanel.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </DockPanel.Resources>
        <Border
            Margin="10"
            Padding="10"
            BorderBrush="Gainsboro"
            BorderThickness="0,0,1,0"
            DockPanel.Dock="Left">
            <StackPanel>
                <TextBlock
                    x:Name="PrinterName"
                    Margin="3"
                    FontSize="16" />
                <TextBlock
                    x:Name="FirmwareVersion"
                    Margin="3"
                    FontSize="12" />
                <TextBlock
                    x:Name="RecordNumber"
                    Margin="30,3"
                    FontSize="14" />
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button
                        Margin="10,5"
                        Padding="10,5"
                        Click="Start_Click"
                        Content="Start" />
                    <Button
                        Margin="10,5"
                        Padding="10,5"
                        Click="Stop_Click"
                        Content="Stop" />
                </StackPanel>
                <Image
                    x:Name="Zion"
                    Width="100"
                    Margin="10"
                    Source="Images/Zion.jpg" />
                <DockPanel>
                    <TextBlock Text="Copies" />
                    <TextBox
                        x:Name="Copies"
                        Margin="10,3"
                        Text="1" />
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Quality (1-3):" Margin="0,3" />
                    <TextBox
                        x:Name="PrintQuality"
                        Margin="10,3"
                        Text="1" />
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Intensity" />
                    <TextBox
                        x:Name="Intensity"
                        Margin="10,3"
                        Text="90" />
                </DockPanel>
                <DockPanel>
                    <CheckBox
                        x:Name="Rotate180"
                        Margin="0,5"
                        Content="Rotate Image 180" />
                </DockPanel>
                <DockPanel>
                    <CheckBox x:Name="MirrorImage" Content="Mirror Image" />
                </DockPanel>
                <Button
                    Margin="10,10,10,5"
                    Padding="10,5"
                    Click="SendImagePrint_Click"
                    Content="Send Print" />


            </StackPanel>
        </Border>

        <StackPanel Margin="10">
            <StackPanel.Resources>
                <Style TargetType="Label">
                    <Setter Property="Width" Value="150" />
                    <Setter Property="Margin" Value="10" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Foreground" Value="DimGray" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                </Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Margin" Value="10" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="10" />
                    <Setter Property="Padding" Value="3" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </StackPanel.Resources>
            <StackPanel Orientation="Horizontal">
                <Label Content="Current State" />
                <TextBlock x:Name="CurrentState" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Error List" />
                <ItemsControl x:Name="ErrorList" />


            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Cartridge Remaining" />
                <TextBlock x:Name="CartridgeRemaining" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label x:Name="PaperRemainingLabel" Content="Paper Remaining" />
                <TextBlock x:Name="PaperRemaining" />
            </StackPanel>
            <Separator
                Margin="0,5"
                BorderBrush="Gainsboro"
                BorderThickness="0,0,0,1" />
            <StackPanel Orientation="Horizontal">
                <Label Content="Top of Form Offset (mm)" />
                <TextBox x:Name="TopOfForm" />
                <Button
                    Margin="10"
                    Padding="10,5"
                    Click="SetTopOfForm_Click"
                    Content="Set" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Horizontal Offset (mm)" />
                <TextBox x:Name="HorizontalOffset" />
                <Button
                    Margin="10"
                    Padding="10,5"
                    Click="SetHorizontalOffset_Click"
                    Content="Set" />
            </StackPanel>
            <Button
                Margin="10,5"
                Padding="10,5"
                HorizontalAlignment="Left"
                Click="SendPrint_Click"
                Content="Send Offsets Print" />
            <Separator
                Margin="0,5"
                BorderBrush="Gainsboro"
                BorderThickness="0,0,0,1" />
        </StackPanel>

    </DockPanel>
</Window>
